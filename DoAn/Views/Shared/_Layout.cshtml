@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hệ Thống Thuê Lái Xe Hộ</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-shield-check"></i> THUÊ XE HỘ
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>

                        @* PHÂN QUYỀN CHO KHÁCH HÀNG (QUÂN) *@
                        @if (Context.Session.GetString("UserRole") == "Customer")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary fw-bold" asp-controller="Trips" asp-action="Create">
                                    <i class="bi bi-plus-circle"></i> Đặt tài xế
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Trips" asp-action="MyTrips">Chuyến đi của tôi</a>
                            </li>
                        }

                        @* PHÂN QUYỀN CHO TÀI XẾ (KHÔI) *@
                        @if (Context.Session.GetString("UserRole") == "Driver")
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold" asp-controller="Trips" asp-action="Index">
                                    <i class="bi bi-search"></i> Tìm cuốc xe
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Trips" asp-action="DriverHistory">Lịch sử nhận chuyến</a>
                            </li>
                        }
                    </ul>

                    @* PHẦN HIỂN THỊ TÀI KHOẢN VÀ ĐĂNG XUẤT *@
                    <ul class="navbar-nav">
                        @if (Context.Session.GetString("UserName") != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-dark fw-bold" href="#" id="userMenu" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> @Context.Session.GetString("UserName")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    <li><span class="dropdown-item-text small text-muted">Quyền: @Context.Session.GetString("UserRole")</span></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item text-danger" asp-controller="Users" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Users" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm ms-2 px-3 rounded-pill" asp-controller="Users" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted border-top bg-light">
        <div class="container py-3 text-center">
            &copy; 2026 - Dự án Drunk Driving Service - <b>Quân & Khôi</b>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>