@model DoAn.Models.User

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 main-card">
            <h2 class="text-center text-primary mb-4">Đăng Nhập</h2>
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">@ViewBag.Error</div>
            }
            <form asp-action="Login" method="post">
                <div class="mb-3">
                    <label class="form-label">Số điện thoại</label>
                    <input name="phone" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Mật khẩu</label>
                    <input name="password" type="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100 btn-custom">Đăng nhập</button>
            </form>
            <div class="mt-3 text-center">
                <p>Chưa có tài khoản? <a asp-action="Register">Đăng ký ngay</a></p>
            </div>
        </div>
    </div>
</div>