@model DoAn.Models.Trip

@{
    ViewData["Title"] = "Đặt Tài Xế Mới";
}

<div class="container mt-5 pt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="glass-card p-5 animate__animated animate__fadeInUp">
                <div class="text-center mb-4">
                    <h2 class="text-warning fw-bold">ĐẶT TÀI XẾ PRO</h2>
                    <p class="text-secondary">An toàn - Nhanh chóng - Chuyên nghiệp</p>
                </div>

                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label class="form-label text-light">Điểm Đón</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark text-danger border-secondary"><i class="bi bi-geo-alt-fill"></i></span>
                            <input asp-for="PickupLocation" class="form-control bg-dark text-light border-secondary" placeholder="Nhập địa chỉ bạn đang đứng..." required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-light">Điểm Đến</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark text-info border-secondary"><i class="bi bi-geo-fill"></i></span>
                            <input asp-for="DropoffLocation" class="form-control bg-dark text-light border-secondary" placeholder="Nhập điểm bạn muốn đến..." required />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-light">Mức giá đề xuất (VNĐ)</label>
                        <div class="input-group">
                            <span class="input-group-text bg-dark text-success border-secondary"><i class="bi bi-cash-stack"></i></span>
                            <input asp-for="Price" type="number" class="form-control bg-dark text-light border-secondary" placeholder="Ví dụ: 200000" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-gold w-100 py-3 fs-5">
                        <i class="bi bi-car-front-fill me-2"></i> TÌM TÀI XẾ NGAY
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>