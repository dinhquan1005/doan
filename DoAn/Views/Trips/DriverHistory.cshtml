@model IEnumerable<DoAn.Models.Trip>
@{
    var total = Model.Where(t => t.Status == DoAn.Models.TripStatus.Completed).Sum(t => t.Price);
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-success fw-bold">Lịch sử lái hộ</h2>
        <h4 class="text-danger">Tổng thu nhập: @total.ToString("N0")đ</h4>
    </div>
    <div class="table-responsive main-card">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Lộ trình</th>
                    <th>Giá</th>
                    <th>Trạng thái</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <b>Từ:</b> @item.PickupLocation <br />
                            <b>Đến:</b> @item.DropoffLocation
                        </td>
                        <td class="fw-bold">@item.Price.ToString("N0")đ</td>
                        <td><span class="badge bg-info">@item.Status</span></td>
                        <td>
                            @if (item.Status == DoAn.Models.TripStatus.Cancelled)
                            {
                                <form asp-action="Complete" asp-route-id="@item.TripID" method="post">
                                    <button type="submit" class="btn btn-success btn-sm">Hoàn thành</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>