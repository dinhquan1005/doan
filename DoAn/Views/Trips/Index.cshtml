@model IEnumerable<DoAn.Models.Trip>

@{
    ViewData["Title"] = "Sảnh Chờ Tài Xế";
}

<div class="container mt-5 pt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-warning fw-bold"><i class="bi bi-broadcast me-2"></i>SẢNH CHỜ CUỐC XE</h2>
        <span class="badge bg-danger animate__animated animate__pulse animate__infinite">Đang quét chuyến mới...</span>
    </div>

    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center text-secondary py-5 glass-card">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-3">Hiện chưa có khách hàng nào đặt xe. Vui lòng chờ...</p>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="glass-card p-4 h-100 d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h5 class="text-light mb-1"><i class="bi bi-person-circle text-warning me-2"></i>@item.Customer?.FullName</h5>
                                <small class="text-secondary">@item.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</small>
                            </div>
                            <h4 class="text-success fw-bold m-0">@item.Price.ToString("N0")đ</h4>
                        </div>

                        <div class="flex-grow-1">
                            <p class="mb-2"><i class="bi bi-geo-alt-fill text-danger me-2"></i><strong>Đón:</strong> @item.PickupLocation</p>
                            <p class="mb-3"><i class="bi bi-geo-fill text-info me-2"></i><strong>Đến:</strong> @item.DropoffLocation</p>
                        </div>

                        <form asp-action="Accept" method="post" class="mt-auto">
                            <input type="hidden" name="id" value="@item.TripID" />
                            <button type="submit" class="btn btn-gold w-100 fw-bold">
                                NHẬN CHUYẾN NGAY
                            </button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        // Tự động reload trang mỗi 10 giây (10000 ms) để cập nhật cuốc mới
        setTimeout(function () {
            window.location.reload();
        }, 10000);
    </script>
}