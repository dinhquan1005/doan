@model IEnumerable<DoAn.Models.Trip>
<div class="container mt-4">
    <h2 class="fw-bold mb-4">Chuyến xe của tôi</h2>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-0 border-start border-4 @(item.Status == DoAn.Models.TripStatus.Pending ? "border-warning" : "border-success")">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted">@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</h6>
                            <h5><i class="bi bi-geo-alt text-danger"></i> @item.PickupLocation</h5>
                            <h5><i class="bi bi-flag text-success"></i> @item.DropoffLocation</h5>
                        </div>
                        <div class="text-end">
                            <span class="badge @(item.Status == DoAn.Models.TripStatus.Pending ? "bg-warning" : "bg-success") mb-2">@item.Status</span>
                            <h4 class="text-primary fw-bold">@item.Price.ToString("N0")đ</h4>
                            @if (item.Status == DoAn.Models.TripStatus.Pending)
                            {
                                <form asp-action="Cancel" asp-route-id="@item.TripID" method="post">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Hủy chuyến</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>